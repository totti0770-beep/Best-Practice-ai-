# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://cnpv_user:changeme@localhost:5432/cnpv_db
POSTGRES_PASSWORD=changeme

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://:changeme@localhost:6379
REDIS_PASSWORD=changeme

# ─── MinIO ──────────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=cnpv-documents
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_minio

# ─── JWT ────────────────────────────────────────────────────
JWT_SECRET=change_me_64_char_random_hex_string_here_0000000000000000000000
JWT_REFRESH_SECRET=change_me_64_char_refresh_secret_here_00000000000000000
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
MFA_TEMP_TOKEN_EXPIRY=5m

# ─── AI (Anthropic) ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
EMBEDDING_MODEL=voyage-3
EMBEDDING_DIMENSION=1024
LLM_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.1

# ─── RAG ────────────────────────────────────────────────────
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K_RETRIEVE=20
RAG_TOP_K_RERANK=5
RAG_MIN_CONFIDENCE_THRESHOLD=0.7

# ─── Security ───────────────────────────────────────────────
ENCRYPTION_KEY=change_me_32_byte_hex_for_aes256_encrypt
BCRYPT_ROUNDS=12

# ─── App ────────────────────────────────────────────────────
APP_PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ─── PgAdmin (dev tool) ─────────────────────────────────────
PGADMIN_PASSWORD=admin
